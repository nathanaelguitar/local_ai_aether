# Copy this file to a local, untracked .env only after replacing every
# REPLACE_ME value. Never commit .env or put these values in an image.

# Host path backing the persistent Docker volume. Create and chown it first.
CANOPY_HOST_STORAGE_ROOT=/data/canopy/contributor_pipeline

# The marketing domain remains separate from this API hostname.
CANOPY_CONTRIBUTOR_DOMAIN=contributor-api.canopychat.app

# Generate independently with: openssl rand -hex 32
CANOPY_CONTRIBUTOR_SHARED_SECRET=REPLACE_ME_generate_a_unique_32_byte_upload_secret
CANOPY_CONTRIBUTOR_ADMIN_TOKEN=REPLACE_ME_generate_a_separate_32_byte_admin_token

# In-process protection; also configure Cloudflare rate limiting at the edge.
CANOPY_RATE_LIMIT_REQUESTS_PER_MINUTE=60
CANOPY_REDACTION_THRESHOLD=0

# Scheduled service intervals.
CURATOR_INTERVAL_SECONDS=600
RETENTION_INTERVAL_SECONDS=86400

# Retention is configurable without code changes. Gold is intentionally absent:
# gold/training and gold/eval are retained until explicit deletion.
CANOPY_RAW_RETENTION_DAYS=30
CANOPY_QUARANTINE_RETENTION_DAYS=7
CANOPY_BRONZE_RETENTION_DAYS=90
CANOPY_SILVER_RETENTION_DAYS=90

# Obtain this from the Cloudflare Zero Trust tunnel configuration. Do not
# paste a real token here; provide it through the local .env/environment.
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME_cloudflare_tunnel_token
