:8080 {
    # Cloudflare Tunnel is the only intended ingress. TLS terminates at Cloudflare.
    request_body {
        max_size 4KB
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer
        -Server
    }

    @health path /health /ready
    handle @health {
        reverse_proxy delivery:8792 {
            health_uri /ready
            health_interval 30s
            health_timeout 3s
        }
    }

    handle {
        reverse_proxy delivery:8792 {
            health_uri /ready
            health_interval 30s
            health_timeout 3s
        }
    }
}
