# Copy to .env and fill in all REPLACE_ME values.
# Never commit .env or put secrets in an image.

# Host directory for persistent data (tokens DB + manifest_meta.json).
# Create it and chown to UID 10002 before first run.
CANOPY_DELIVERY_HOST_STORAGE_ROOT=/data/canopy/model_delivery

# Public hostname for this service.
CANOPY_DELIVERY_DOMAIN=model-api.canopychat.app

# HF read token — server-side only, never in iOS source or logs.
CANOPY_DELIVERY_HF_TOKEN=REPLACE_ME_hf_read_token

# HF repo and model file to sync.
CANOPY_DELIVERY_HF_REPO=nathanaelguitar/canopy-1.1.2
CANOPY_DELIVERY_MODEL_FILENAME=canopy-1.1.2.Q4_K_M.gguf
CANOPY_DELIVERY_MODEL_VERSION=1.1.2

# Cloudflare R2 credentials.
# Create an R2 bucket and an API token with Object Read & Write on that bucket.
CANOPY_DELIVERY_R2_ACCOUNT_ID=REPLACE_ME_cf_account_id
CANOPY_DELIVERY_R2_ACCESS_KEY_ID=REPLACE_ME_r2_access_key_id
CANOPY_DELIVERY_R2_SECRET_ACCESS_KEY=REPLACE_ME_r2_secret_access_key
CANOPY_DELIVERY_R2_BUCKET=REPLACE_ME_r2_bucket_name

# Signed URL TTL in seconds (default 900 = 15 min).
# iOS must re-call /v1/model-manifest before this elapses for resume support.
CANOPY_DELIVERY_URL_TTL_SECONDS=900

# Cloudflare Tunnel token. Create a new tunnel in Zero Trust → Access → Tunnels,
# add a Public Hostname rule: model-api.canopychat.app → http://caddy:8080
# OR add the hostname to the existing contributor tunnel.
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME_cloudflare_tunnel_token
